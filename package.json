{
	"name": "@webitel/auth",
	"version": "26.8.0",
	"private": true,
	"scripts": {
		"dev": "vite --force",
		"build": "vite build",
		"test:unit": "vitest",
		"lint:fix": "npx biome check --write ./src",
		"lint:fix-staged": "npx lint-staged",
		"utils:i": "npm i",
		"utils:up-lib": "npm up @webitel/api-services @webitel/ui-sdk && npm run utils:ls-libs",
		"utils:link-libs": "npm link @webitel/api-services @webitel/ui-sdk && npm run utils:ls-libs",
		"utils:ls-libs": "npm ls @webitel/api-services @webitel/ui-sdk ",
		"prepare": "husky || true",
		"biome:ci:gh": "biome ci ./src --reporter=github",
		"test:unit:ci": "vitest run --coverage",
		"typecheck:ci": "true"
	},
	"type": "module",
	"dependencies": {
		"@egjs/flicking-plugins": "^4.7.0",
		"@egjs/vue3-flicking": "^4.10.6",
		"@vuelidate/core": "^2.0.0",
		"@vuelidate/validators": "^2.0.0",
		"@webitel/api-services": "^0.1.47",
		"@webitel/styleguide": "~26.2",
		"@webitel/ui-sdk": "~26.6",
		"axios": "^1.18.1",
		"clipboard-copy": "^4.0.1",
		"deep-copy": "^1.x",
		"http-status-codes": "^2.3.0",
		"mitt": "^3.x",
		"pinia": "^3.0.4",
		"vue": "^3.5.x",
		"vue-i18n": "^11.x",
		"vue-router": "^4.x",
		"vuex": "^4.1.0",
		"webitel-sdk": "^26.4.21"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@vitejs/plugin-vue": "^6.x",
		"@vitest/coverage-v8": "^4.1.10",
		"@vue/compiler-sfc": "^3.5.17",
		"@vue/test-utils": "2.3.0",
		"globals": "^17.x",
		"happy-dom": "^20.10.6",
		"husky": "^9.1.7",
		"lint-staged": "^16.x",
		"sass": "^1.78.0",
		"typescript": "^5.9.x",
		"vite": "npm:rolldown-vite@^7.3.x",
		"vite-plugin-node-polyfills": "^0.x",
		"vitest": "^4.x"
	},
	"overrides": {
		"vite": "npm:rolldown-vite@^7.3.x"
	}
}
